--!strict
-- SharedData: the Luau side of the canonical data file at
-- `src/data/super-chess.json` in the web repo (also served at
-- `/super-chess.json` by the Vite dev server and the deployed Worker).
--
-- Data flow:
--   1. The repo file `src/data/super-chess.json` is the hand-edited source of
--      truth. The web project imports it directly; the Luau project ships an
--      embedded snapshot via `Modules.SuperChessData` (regenerated by
--      `pnpm cards:sync`).
--   2. At server boot we always start with the embedded snapshot — zero-dep,
--      works offline.
--   3. If `SharedData.SOURCE_URL` is set and `HttpService.HttpEnabled` is on,
--      we asynchronously fetch the latest JSON from there and swap it in.
--      Failure (HTTP off, site down, network unreachable) is a no-op: we keep
--      the embedded snapshot.
--
-- Consumers (Cards, Bot, Deck, Rules) call `SharedData.get()` which always
-- returns the latest decoded data; or use the explicit per-section accessors
-- (`SharedData.cards()`, `SharedData.pieceValues()`, etc.).

local HttpService = game:GetService('HttpService')

local SuperChessData = require(script.Parent:WaitForChild('SuperChessData'))

local SharedData = {}

-- Override at runtime (e.g. on a dev machine) to point at the dev server.
-- The empty string disables runtime fetching.
SharedData.SOURCE_URL = ''

export type PieceTypeKey = 'P' | 'N' | 'B' | 'R' | 'Q' | 'K'
export type CardRarity = 'common' | 'uncommon' | 'rare'
-- `default` was added on the web side to support a curated beginner pool
-- (Freeze, Shield, Foul Ground, Pawn Retreat, Double Step, Sidestep).
-- The web client filters by category on the new-game screen; the Roblox
-- client doesn't yet expose that, so it still pulls the whole deck \u2014
-- but the type needs to allow the new value to decode without errors.
export type CardCategory = 'default' | 'movement' | 'disruption' | 'defense' | 'power' | 'chaos'
export type CardTargetType = 'square' | 'ownPiece' | 'oppPiece' | 'pieceType' | 'pawn'
export type CardDef = {
    name: string,
    rarity: CardRarity,
    category: CardCategory,
    copies: number,
    emoji: string?,
    icon: string?,
    shortDesc: string,
    rulesText: string,
    requiresTarget: boolean,
    targetType: CardTargetType?,
    consumesTurn: boolean?,
    -- Short badge label for the in-hand UI ("instant", "opp turn", etc.).
    -- Optional; the Roblox port doesn't use it yet.
    duration: string?,
    -- True iff the card can directly capture an opponent piece.
    capture: boolean?,
}
export type Data = {
    version: string,
    engine: {
        pieceValues: { [PieceTypeKey]: number },
        pieceSquareTables: { [PieceTypeKey]: { number } },
        tempoCompensationCp: number,
        cardEval: {
            frozenPenalty: number,
            shieldBonus: number,
            foulSquarePenalty: number,
        },
    },
    rules: {
        maxHandSize: number,
        maxMovesPerGame: number,
    },
    cards: { CardDef },
}

local current: Data? = nil
local source: string = 'embedded'

local function decode(json: string): Data?
    local ok, decoded = pcall(function() return HttpService:JSONDecode(json) end)
    if not ok or type(decoded) ~= 'table' then return nil end
    return decoded :: any
end

local function loadEmbedded()
    current = decode(SuperChessData.embeddedJson)
    source = 'embedded'
end
loadEmbedded()

function SharedData.get(): Data
    if not current then
        loadEmbedded()
        assert(current ~= nil, 'SuperChessData.embeddedJson failed to decode')
    end
    return current :: Data
end

function SharedData.source(): string
    return source
end

function SharedData.version(): string
    return SharedData.get().version
end

function SharedData.cards(): { CardDef }
    return SharedData.get().cards
end

function SharedData.pieceValues(): { [PieceTypeKey]: number }
    return SharedData.get().engine.pieceValues
end

function SharedData.pieceSquareTables(): { [PieceTypeKey]: { number } }
    return SharedData.get().engine.pieceSquareTables
end

function SharedData.tempoCompensationCp(): number
    return SharedData.get().engine.tempoCompensationCp
end

function SharedData.cardEval()
    return SharedData.get().engine.cardEval
end

function SharedData.maxHandSize(): number
    return SharedData.get().rules.maxHandSize
end

function SharedData.maxMovesPerGame(): number
    return SharedData.get().rules.maxMovesPerGame
end

-- Attempts to fetch `super-chess.json` from `SharedData.SOURCE_URL` and swap it
-- in. Returns true on success, false otherwise (e.g. HttpService disabled,
-- network failure, malformed JSON).
function SharedData.tryFetchFresh(): (boolean, string?)
    if SharedData.SOURCE_URL == nil or SharedData.SOURCE_URL == '' then
        return false, 'SharedData.SOURCE_URL is empty'
    end
    local ok, response = pcall(function()
        return HttpService:GetAsync(SharedData.SOURCE_URL)
    end)
    if not ok then
        return false, tostring(response)
    end
    local decoded = decode(response)
    if not decoded then
        return false, 'JSON decode failed'
    end
    current = decoded
    source = 'fetched: ' .. SharedData.SOURCE_URL
    return true
end

return SharedData
